# ---- VFIC Box Operations — environment ----
# Local dev needs NONE of these (falls back to filesystem + console SMS).
# On Vercel, set these in Project Settings → Environment Variables.

# Session signing secret (REQUIRED in production). Generate: openssl rand -base64 32
SESSION_SECRET=

# --- Data store (REQUIRED in production) — pick ONE backend ---
# Option A: Supabase (Postgres). Create a project, run in the SQL editor:
#   create table if not exists kv (k text primary key, v jsonb);
# Then copy Project URL + the SERVICE ROLE key (Settings → API). Service role is
# secret — server-side only, never in client code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_TABLE=kv        # optional (default: kv)

# Option B: Vercel KV / Upstash Redis (auto-set by the integration; either name pair works)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: key/row the DB document is stored under (default: vfic:db)
# KV_DB_KEY=vfic:db

# --- File storage: Vercel Blob (REQUIRED in production for uploads) ---
# Auto-set when you add the Vercel Blob store.
BLOB_READ_WRITE_TOKEN=

# --- Cron auth: protects /api/cron/process-notifications ---
# Set a random value; Vercel Cron sends it as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# --- SMS provider (optional; default = console/simulated) ---
# SMS_PROVIDER=semaphore
# SEMAPHORE_API_KEY=
# SEMAPHORE_SENDER_NAME=VFIC

# Public base URL used in SMS links / QR codes (e.g. https://your-app.vercel.app)
# PUBLIC_BASE_URL=
